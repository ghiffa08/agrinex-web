							"mode": "raw",
							"raw": "{\n  \"metadata\": {\n    \"sesi_id_getdata\": {{sesi_id}},\n    \"timestamp\": \"{{$timestamp}}\",\n    \"source\": \"Postman Test\",\n    \"version\": \"2.0\",\n    \"device_id\": \"RPI-001\"\n  },\n  \"data\": {\n    \"getdata_logs\": [\n      {\n        \"sesi_id_getdata\": {{sesi_id}},\n        \"waktu_mulai\": \"2025-10-15 10:00:00\",\n        \"waktu_selesai\": \"2025-10-15 10:30:00\",\n        \"jumlah_node\": 12,\n        \"node_sukses\": 12,\n        \"node_gagal\": 0,\n        \"status\": \"completed\",\n        \"keterangan\": \"Test from Postman\"\n      }\n    ],\n    \"sensor_weather_data\": [\n      {\n        \"sesi_id_getdata\": {{sesi_id}},\n        \"node_id\": 0,\n        \"voltage\": 3.35,\n        \"current\": 125,\n        \"power\": 418,\n        \"light\": 850,\n        \"rain\": 0,\n        \"rain_adc\": 1023,\n        \"wind\": 5.2,\n        \"wind_pulse\": 52,\n        \"humidity\": 65.5,\n        \"temp_dht\": 28.5,\n        \"ts_counter\": 12345,\n        \"received_at\": \"2025-10-15 10:30:00\"\n      }\n    ],\n    \"sensor_node_data\": [\n      {\n        \"sesi_id_getdata\": {{sesi_id}},\n        \"node_id\": 1,\n        \"voltage_v\": 3.3,\n        \"current_ma\": 120,\n        \"power_mw\": 396,\n        \"temp_c\": 28.5,\n        \"soil_pct\": 45.2,\n        \"soil_adc\": 512,\n        \"ts_counter\": 12345,\n        \"received_at\": \"2025-10-15 10:30:00\"\n      },\n      {\n        \"sesi_id_getdata\": {{sesi_id}},\n        \"node_id\": 2,\n        \"voltage_v\": 3.28,\n        \"current_ma\": 118,\n        \"power_mw\": 387,\n        \"temp_c\": 29.1,\n        \"soil_pct\": 52.8,\n        \"soil_adc\": 478,\n        \"ts_counter\": 12346,\n        \"received_at\": \"2025-10-15 10:30:00\"\n      }\n    ],\n    \"node_logs\": [\n      {\n        \"sesi_id\": {{sesi_id}},\n        \"node_id\": 0,\n        \"rssi_dbm\": -72,\n        \"snr_db\": 9.5,\n        \"signal_quality\": \"Excellent\",\n        \"status\": \"Aktif\",\n        \"waktu\": \"2025-10-15 10:30:00\",\n        \"type_sesi\": \"getdata\",\n        \"keterangan\": \"Weather station OK\"\n      },\n      {\n        \"sesi_id\": {{sesi_id}},\n        \"node_id\": 1,\n        \"rssi_dbm\": -75,\n        \"snr_db\": 8.5,\n        \"signal_quality\": \"Good\",\n        \"status\": \"Aktif\",\n        \"waktu\": \"2025-10-15 10:30:00\",\n        \"type_sesi\": \"getdata\",\n        \"keterangan\": \"Node 1 OK\"\n      },\n      {\n        \"sesi_id\": {{sesi_id}},\n        \"node_id\": 2,\n        \"rssi_dbm\": -78,\n        \"snr_db\": 7.8,\n        \"signal_quality\": \"Good\",\n        \"status\": \"Aktif\",\n        \"waktu\": \"2025-10-15 10:30:00\",\n        \"type_sesi\": \"getdata\",\n        \"keterangan\": \"Node 2 OK\"\n      }\n    ]\n  },\n  \"statistics\": {\n    \"total_records\": 7,\n    \"records_by_table\": {\n      \"getdata_logs\": 1,\n      \"sensor_weather_data\": 1,\n      \"sensor_node_data\": 2,\n      \"node_logs\": 3\n    },\n    \"node_status\": {\n      \"expected_nodes\": 12,\n      \"received_nodes\": 3,\n      \"completeness_percentage\": \"25.00%\"\n    }\n  }\n}"
